{
  "$id": "game-mechanics-index/gameplay-map.schema.json",
  "title": "GameplayMap",
  "description": "Gameplay map document analyzing a game or defining a genre recipe",
  "type": "object",
  "required": [
    "schema_version",
    "slug",
    "title",
    "map_type",
    "source_url",
    "subject",
    "narrative",
    "signature_gameplay",
    "mechanics",
    "views"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.1", "1.2"] },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "map_type": { "type": "string", "enum": ["game", "genre"] },
    "source_url": { "type": "string", "format": "uri" },
    "subject": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string", "enum": ["game", "genre"] },
        "name": { "type": "string", "minLength": 1 },
        "genres": { "type": "array", "items": { "type": "string" } },
        "influences": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "narrative": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "core_loop": { "type": "string" },
        "skills_tested": { "type": "array", "items": { "type": "string" } },
        "design_pillars": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "properties": {
        "year": { "type": "integer" },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "perspective": { "type": "string" },
        "dimension": { "type": "string" },
        "player_count": {
          "type": "object",
          "properties": {
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "session_type": { "type": "string" },
        "world_structure": { "type": "string" }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "quality_tier": {
          "type": "string",
          "enum": ["curated", "catalog", "template", "stub"]
        }
      },
      "additionalProperties": false
    },
    "relationships": {
      "type": "object",
      "properties": {
        "similar_to": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } },
        "genre_maps": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } },
        "influence_slugs": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } }
      },
      "additionalProperties": false
    },
    "design_intent": {
      "type": "object",
      "properties": {
        "player_fantasy": { "type": "string" },
        "emotional_tone": { "type": "array", "items": { "type": "string" } },
        "theme_tags": { "type": "array", "items": { "type": "string" } },
        "design_pillars": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "systems": {
      "type": "object",
      "properties": {
        "primary_loop_phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "mechanics": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "failure_model": { "type": "string" },
        "economy_tightness": { "type": "string" },
        "metaprogression": { "type": "boolean" },
        "pacing": {
          "type": "object",
          "properties": {
            "early": { "type": "string" },
            "mid": { "type": "string" },
            "late": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "composition": {
      "type": "object",
      "properties": {
        "base_genre_maps": { "type": "array", "items": { "type": "string" } },
        "reference_games": { "type": "array", "items": { "type": "string" } },
        "customization_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "add_signatures": { "type": "array", "items": { "type": "string" } },
          "drop_signatures": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "signature_gameplay": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
    },
    "mechanics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mechanic_slug", "role", "domain"],
        "properties": {
          "mechanic_slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "role": { "type": "string", "enum": ["signature", "supporting", "common"] },
          "map_notes": { "type": "string" },
          "domain": { "type": "string", "enum": ["locomotion", "combat", "progression", "economy", "level", "session"] },
          "phase": { "type": "string", "enum": ["early", "mid", "late", "optional"] },
          "weight": { "type": "integer", "minimum": 1, "maximum": 5 },
          "expression": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" } },
          "optional": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "filter"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 },
          "filter": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["signature", "supporting", "common"] },
              "flavor": { "type": "string", "enum": ["action", "adventure", "strategy"] },
              "genre_filter": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "gdd_outline": {
      "type": "object",
      "properties": {
        "overview": { "type": "string" },
        "core_loop": { "type": "string" },
        "player_goals": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "progression_notes": { "type": "string" },
        "combat_notes": { "type": "string" },
        "economy_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "mechanic_relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_mechanic", "to_mechanic"],
        "properties": {
          "from_mechanic": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "to_mechanic": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "relationship": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
