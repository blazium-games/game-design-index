{
  "$id": "game-mechanics-index/public/mechanic-entry.schema.json",
  "title": "PublicMechanicEntry",
  "description": "Public mechanic entry (implementation and media stripped at export)",
  "type": "object",
  "required": ["schema_version", "slug", "name", "flavor", "domain", "summary", "tags"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.2" },
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "flavor": { "type": "string", "enum": ["action", "adventure", "strategy"] },
    "domain": { "type": "string" },
    "summary": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "flavor_rationale": { "type": "string" },
    "design_guidance": { "type": "object" },
    "synergy_notes": { "type": "array" },
    "player_experience": { "type": "string" },
    "complexity": { "type": "string", "enum": ["S", "M", "L"] },
    "examples": { "type": "array" },
    "relationship_model": { "type": "object" },
    "agent_context": { "type": "object" }
  }
}
